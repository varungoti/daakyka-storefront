{
  "buildCommand": "node scripts/vercel-build.mjs",
  "installCommand": "npm ci",
  "functions": {
    "src/app/api/hermes/runtime/tasks/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/hermes/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/outfit/try-on/route.ts": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/cron/journeys",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/hermes",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/reports",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/campaigns",
      "schedule": "0 10 * * *"
    }
  ]
}
