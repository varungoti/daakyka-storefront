{
  "name": "storefront",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "tsx --test src/lib/auth/rbac.test.ts src/lib/auth/admin-security.test.ts src/lib/auth/session-cookie.test.ts src/lib/currency/convert.test.ts src/lib/seo/audit.test.ts src/lib/seo/schema-validation.test.ts src/lib/validation/schemas.test.ts src/lib/hermes/safety.test.ts src/lib/reports/weekly-growth.test.ts src/lib/shop/filters.test.ts src/lib/env.test.ts src/lib/shopify/webhook-verify.test.ts src/lib/security/parse-json-body.test.ts src/lib/create-prisma-client.test.ts src/data/media/catalog.test.ts src/lib/engagement/template.test.ts src/lib/mix-match/resolve-products.test.ts",
    "test:integration": "tsx --test tests/integration/api-routes.test.ts",
    "test:smoke": "tsx --test tests/smoke/pages.test.ts",
    "test:e2e": "playwright test tests/e2e/storefront.spec.ts tests/e2e/admin.spec.ts",
    "test:dogfood": "playwright test tests/e2e/dogfood.spec.ts",
    "verify": "npm run lint && npm run test && npm run build",
    "verify:full": "npm run verify && npm run test:smoke && npm run test:e2e",
    "verify:101": "node scripts/verify-101.mjs",
    "verify:staging": "node scripts/verify-staging.mjs",
    "verify:staging:full": "node scripts/verify-staging-full.mjs",
    "verify:predeploy": "node scripts/predeploy-verify.mjs",
    "check:deploy-env": "node scripts/check-deploy-env.mjs",
    "go-live:check": "node scripts/go-live-check.mjs",
    "wire:ar-staging": "node scripts/wire-ar-staging.mjs",
    "bootstrap:staging": "node scripts/bootstrap-staging.mjs",
    "probe:deploy": "node scripts/probe-deploy.mjs",
    "audit:lighthouse": "node scripts/lighthouse-audit.mjs",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma migrate deploy && tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
